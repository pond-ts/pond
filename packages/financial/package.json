{
  "name": "@pond-ts/financial",
  "version": "0.51.0",
  "private": false,
  "description": "Financial-market domain library on pond-ts — trading calendars, session-aligned bar building, and market analytics",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pond-ts/pond.git",
    "directory": "packages/financial"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/cjs-fallback.cjs"
    },
    "./fluent": {
      "types": "./dist/fluent.d.ts",
      "import": "./dist/fluent.js"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "prepack": "cp ../../LICENSE ./LICENSE && cp ../../CHANGELOG.md ./CHANGELOG.md && npm run build && cp cjs-fallback.cjs dist/cjs-fallback.cjs && find dist -name '*.map' -delete",
    "test": "npm run test:type && npm run test:runtime",
    "test:type": "tsc -p tsconfig.types.json",
    "test:runtime": "vitest run",
    "verify": "npm run format:check && npm run build && npm test"
  },
  "dependencies": {
    "@js-temporal/polyfill": "^0.5.1"
  },
  "peerDependencies": {
    "pond-ts": "^0.51.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
