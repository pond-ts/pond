{
  "name": "@pond-ts/charts",
  "version": "0.52.0",
  "private": false,
  "description": "Canvas-rendered, streaming-first time-series charts for pond-ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pond-ts/pond.git",
    "directory": "packages/charts"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/cjs-fallback.cjs"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "cp ../../LICENSE ./LICENSE && cp ../../CHANGELOG.md ./CHANGELOG.md && npm run build && cp cjs-fallback.cjs dist/cjs-fallback.cjs && find dist -name '*.map' -delete",
    "test": "npm run test:type && npm run test:runtime",
    "test:type": "tsc -p tsconfig.types.json",
    "test:runtime": "vitest run",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:e2e": "playwright test",
    "perf": "PERF_BENCH=1 playwright test perf.spec.ts --workers=1"
  },
  "peerDependencies": {
    "@pond-ts/react": "^0.52.0",
    "pond-ts": "^0.52.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@storybook/react-vite": "^10.4.6",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-shape": "^3.1.8",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.2.3",
    "happy-dom": "^20.9.0",
    "http-server": "^14.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.2.5",
    "storybook": "^10.4.6",
    "typescript": "^5.6.3",
    "vite": "^5.4.21",
    "vitest": "^2.1.4"
  },
  "dependencies": {
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0"
  }
}
