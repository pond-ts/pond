{
  "name": "pond-ts",
  "version": "0.28.0",
  "description": "TypeScript-first time series primitives",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pjm17971/pond-ts.git",
    "directory": "packages/core"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": [
    "./dist/column.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/cjs-fallback.cjs"
    },
    "./types": {
      "types": "./dist/schema/public.d.ts",
      "import": "./dist/schema/public.js"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"test-d/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\" \"test-d/**/*.ts\"",
    "prepack": "cp ../../README.md ./README.md && cp ../../LICENSE ./LICENSE && cp ../../CHANGELOG.md ./CHANGELOG.md && npm run build && cp cjs-fallback.cjs dist/cjs-fallback.cjs && find dist -name '*.map' -delete",
    "test": "npm run test:type && npm run test:runtime",
    "test:runtime": "vitest run",
    "test:type": "tsc -p tsconfig.types.json",
    "verify": "npm run format:check && npm run build && npm test"
  },
  "devDependencies": {
    "@babel/runtime": "^7.29.2",
    "@types/node": "^20.17.0",
    "pondjs": "^0.9.0",
    "prettier": "^3.8.3",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "dependencies": {
    "@js-temporal/polyfill": "^0.5.1"
  }
}
