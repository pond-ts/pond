# Scratch agent-run materials — prompts, fixtures, rubrics. Not shipped.
experiments/

# Claude Code local state (worktrees, per-machine settings).
.claude/

# README, LICENSE, CHANGELOG copied into each package by `prepack`
# so the published npm tarball includes them. Sources of truth are
# the repo-root files; the per-package copies are build artifacts.
# Exception: @pond-ts/charts and @pond-ts/fit ship their OWN committed
# README (their prepack does not copy the root one) — see the negations.
packages/*/README.md
!packages/charts/README.md
!packages/fit/README.md
packages/*/LICENSE
packages/*/CHANGELOG.md
