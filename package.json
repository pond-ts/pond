{
  "private": true,
  "name": "pond-ts-monorepo",
  "description": "pond-ts monorepo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pjm17971/pond-ts.git"
  },
  "workspaces": [
    "packages/core",
    "packages/react",
    "packages/charts",
    "packages/fit"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces --if-present",
    "format": "prettier --write \"packages/*/{src,test}/**/*.{ts,tsx}\" \"website/**/*.{md,mdx,ts,tsx,js,jsx,json,css}\"",
    "format:check": "prettier --check \"packages/*/{src,test}/**/*.{ts,tsx}\" \"website/**/*.{md,mdx,ts,tsx,js,jsx,json,css}\"",
    "verify": "npm run format:check && npm run build && npm test"
  },
  "devDependencies": {
    "prettier": "^3.8.3"
  }
}
